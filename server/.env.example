# ─── Server (Express) environment variables ──────────────────────────────────
# Copy this file to server/.env and fill in real values.
# NEVER commit server/.env — it is in .gitignore.

# Port for the Express server (default: 5000)
PORT=5000

# Allowed frontend origins (comma-separated) for CORS.
# Set this to your deployed Vercel URL in production.
# Leave blank/unset in development to allow all origins.
# Example: ALLOWED_ORIGINS=https://aage-kya.vercel.app,https://www.aagekya.com
# ALLOWED_ORIGINS=

# Groq API key (server-side ONLY — never use VITE_ prefix for this)
# Get your FREE key from: https://console.groq.com → API Keys
# Model used: llama-3.3-70b-versatile (default) — override with GROQ_MODEL env var
GROQ_API_KEY=your_groq_api_key_here

# Supabase project credentials (same project as frontend)
# Get from: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://qtzapzvrimdryuuebiiz.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InF0emFwenZyaW1kcnl1dWViaWl6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM0Nzg3NTEsImV4cCI6MjA5OTA1NDc1MX0.ctXP4UUlpCnOz_OwuuGDZi9vhQ5KQ4nyDsjAcPZZdIU

# Supabase Service Role Key (OPTIONAL for analytics, REQUIRED for seed.js)
# Used by GET /api/analytics and node seed.js (Phase 3 RAG seeding).
# CAUTION: This key bypasses Row Level Security. Keep it server-side only.
# Get from: Supabase dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InF0emFwenZyaW1kcnl1dWViaWl6Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MzQ3ODc1MSwiZXhwIjoyMDk5MDU0NzUxfQ.JNy7CEjkyCF97YGetGci3mVLkMpaugc07j42UKgsnD8

# ─── Phase 3: RAG Data Setup ──────────────────────────────────────────────────
# After filling in the keys above and running supabase_schema.sql:
#   cd server && node seed.js
# This seeds ~108 real colleges and 25 verified scholarships into Supabase.
# The /api/guidance endpoint will use this data to ground the AI's responses.

# ─── Optional: Override AI model ─────────────────────────────────────────────
# Default model: llama-3.3-70b-versatile
# Other fast Groq options: llama-3.1-8b-instant, mixtral-8x7b-32768
# GROQ_MODEL=llama-3.3-70b-versatile
