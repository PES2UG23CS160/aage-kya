# ─── Frontend (Vite) environment variables ───────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.

# Supabase project credentials (get from: Supabase dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─── NOTE ────────────────────────────────────────────────────────────────────
# The Gemini API key is intentionally NOT listed here.
# It lives in server/.env as GEMINI_API_KEY (server-side only, never exposed to the browser).
# See server/.env.example for the full list of server environment variables.